# Machine-specific overrides — copy to config.local.env (gitignored):
#   cp acquire/config.local.env.example acquire/config.local.env
#
# Portable defaults live in config.env.example; only set overrides here.

IMMIGRATION_FISCAL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export REPO_ROOT="${REPO_ROOT:-$(cd "$IMMIGRATION_FISCAL_ROOT/../.." && pwd)}"

