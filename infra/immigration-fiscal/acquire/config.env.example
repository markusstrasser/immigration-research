# Copy to config.local.env and edit paths for your machine.
#   cp acquire/config.env.example acquire/config.local.env
#
# All acquisition scripts read PNY_DATA_ROOT (historical name = "data root").

IMMIGRATION_FISCAL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Where raw zips/CSVs land (~50GB+ for full stack). Override on a new machine:
export PNY_DATA_ROOT="${IMMIGRATION_DATA_ROOT:-$HOME/research-data/immigration-fiscal/data}"

# Large mirrors (ACS corpus, IRS SOI migration panel). Optional but used by setup.sh:
export CORPUS_ROOT="${IMMIGRATION_CORPUS_ROOT:-$HOME/research-data/corpus}"

# Python builders + stage CSV outputs (git-tracked under infra/immigration-fiscal/build/):
export DERIVED_ROOT="${IMMIGRATION_DERIVED_ROOT:-$IMMIGRATION_FISCAL_ROOT/build}"

# Slim warehouse (aggregates only, not raw microdata):
export DUCKDB_PATH="${IMMIGRATION_DUCKDB_PATH:-$HOME/Projects/research/warehouse/immigration_context.duckdb}"
