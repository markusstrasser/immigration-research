# Copy to config.local.env and edit paths for your machine:
#   cp acquire/config.env.example acquire/config.local.env
#
# Or run:  ./reproduce.sh init

IMMIGRATION_FISCAL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export REPO_ROOT="${REPO_ROOT:-$(cd "$IMMIGRATION_FISCAL_ROOT/../.." && pwd)}"

# Raw zips/CSVs (~2 GB minimum, ~50 GB full stack)
export PNY_DATA_ROOT="${IMMIGRATION_DATA_ROOT:-$HOME/research-data/immigration-fiscal/data}"

# Optional large mirrors (ACS corpus zip, IRS SOI migration panel)
export CORPUS_ROOT="${IMMIGRATION_CORPUS_ROOT:-$HOME/research-data/corpus}"

# Builder CSV outputs (DuckDB _tmp extracts, stage2/3/5 derived tables)
export DERIVED_ROOT="${IMMIGRATION_DERIVED_ROOT:-$PNY_DATA_ROOT/derived}"

# Warehouses (slim aggregates — safe to keep in repo workspace/)
export DUCKDB_PATH="${IMMIGRATION_DUCKDB_PATH:-$REPO_ROOT/warehouse/immigration_context.duckdb}"
export LIFETIME_DUCKDB_PATH="${LIFETIME_DUCKDB_PATH:-$REPO_ROOT/warehouse/immigration_lifetime_evidence.duckdb}"
export FISCAL_UNION_DUCKDB_PATH="${FISCAL_UNION_DUCKDB_PATH:-$REPO_ROOT/warehouse/immigration_fiscal_union.duckdb}"

# Causal stack (Saiz, BEA I-O, county panels) — separate tree under sources/
export IMMIGRATION_CAUSAL_DATA="${IMMIGRATION_CAUSAL_DATA:-$REPO_ROOT/sources/immigration-causal/data}"
